# ── LLM (Cloud API) ──
# Option A (Groq): https://api.groq.com/openai/v1 / llama3-8b-8192
# Option B (Nvidia): https://integrate.api.nvidia.com/v1 / meta/llama-3.1-8b-instruct
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama3-8b-8192
EMBED_MODEL=nomic-embed-text-v1_5

# ── Database (PostgreSQL + PostGIS) ──
DATABASE_URL=postgresql+asyncpg://remedy:remedy@localhost:5432/remedyradar

# ── ChromaDB ──
CHROMA_PERSIST_DIR=./chroma_data

# ── App Settings ──
DEFAULT_SEARCH_RADIUS_KM=10
MAX_SEARCH_RADIUS_KM=50
TOP_N_DOCTORS=5
LOG_LEVEL=INFO
